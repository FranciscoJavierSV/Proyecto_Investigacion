config:
  target: "http://localhost:4000"
  phases:
    - duration: 15
      arrivalRate: 10
      name: "Prueba de carga REST con 50 req/sec"

scenarios:
  - name: "Consultar REST"
    flow:
      - get:
          url: "/rest/?size=50&offset=0"
          expect:
            - statusCode: 200
# Run: npx artillery run scripts/concurrencia-rest.yml -o logs/artillery_rest.json
